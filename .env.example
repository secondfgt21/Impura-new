# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_SUPABASE_URL: The URL of your Supabase project (exposed to frontend)
VITE_SUPABASE_URL="https://your-supabase-project.supabase.co"

# VITE_SUPABASE_ANON_KEY: The anonymous key for Supabase (exposed to frontend)
VITE_SUPABASE_ANON_KEY="your-anon-key"

# SUPABASE_SERVICE_ROLE_KEY: The secret service role key for Supabase (backend only)
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ADMIN_TOKEN: Secret token used to access the admin panel securely (backend only)
ADMIN_TOKEN="ganti-tokenmu"
